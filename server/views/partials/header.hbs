<header>
  <div class="logo-wrapper">
    <a class="logo nav" href="/" title="Homepage">
      <img src="/images/logo.png" alt="{{site_name}}" width="18" height="24" />
      {{site_name}}
    </a>
  </div>
  <nav>
    <ul>
      {{#if user}}
        <li>
          <a class="button primary" href="/dashboard" title="Dashboard">
            <span>{{> icons/chart}}</span>
            Dashboard
          </a>
        </li>
        <li>
          <a class="button primary" href="/" title="Criar link">
            <span>{{> icons/plus}}</span>
            Criar Link
          </a>
        </li>
        <li>
          <a class="button primary" href="/settings" title="Settings">
            <span>{{> icons/cog}}</span>
            Settings
          </a>
        </li>
        {{#if isAdmin}}
          <li>
            <a class="button secondary" href="/admin" title="Admin">
              <span>{{> icons/shield}}</span>
              Admin
            </a>
          </li>
        {{/if}}
        <li>
          <a class="button" href="/api/docs" target="_blank" rel="noopener noreferrer" title="API Docs">
            Docs
          </a>
        </li>
        <li>
          <a class="nav" href="/logout" title="Log out">Log out</a>
        </li>
      {{/if}}
      {{#unless user}}
        {{#unless login_disabled}}
          <li>
            <a class="button primary" href="/login" title="Log in">Log in</a>
          </li>
        {{/unless}}
      {{/unless}}
      <li>
        <button type="button" class="nav dark-toggle" id="dark-mode-toggle" onclick="toggleDarkMode()" title="Alternar tema" aria-label="Toggle dark mode">
          <span class="dark-icon-moon">🌙</span>
          <span class="dark-icon-sun hidden">☀️</span>
        </button>
      </li>
    </ul>
  </nav>
</header>

<main>
  <div id="shorturl">
    {{#if link}}
      <div class="clipboard">
        <button 
          type="button"
          aria-label="Copy" 
          hx-on:click="handleShortURLCopyLink(this);" 
          data-url="{{url}}"
        >
        {{> icons/copy}}
        </button>
        {{> icons/check}}
      </div>
      <h1 
        class="link" 
        hx-on:click="handleShortURLCopyLink(this);" 
        data-url="{{url}}"
      >
        {{link}}
      </h1>
    {{/if}}
    {{#unless link}}
        <h1>Cut your links <span>shorter</span>.</h1>
    {{/unless}}
  </div>
  <form 
    id="shortener-form" 
    hx-post="/api/links" 
    hx-trigger="submit queue:none" 
    hx-target="closest main" 
    hx-swap="outerHTML" 
    autocomplete="off"
  >
    <div class="target-wrapper {{#if errors.target}}error{{/if}}">
      <input
        id="target"
        name="target"
        type="text"
        placeholder="Paste your long URL"
        aria-label="target"
        autofocus="true"
        data-lpignore="true"
        hx-preserve="true"
      />
      <button class="submit">
        {{> icons/send}}
        {{> icons/spinner}}
      </button>
      {{#if errors.target}}<p class="error">{{errors.target}}</p>{{/if}}
      {{#unless errors}}
        {{#if error}}
          <p class="error">{{error}}</p>
        {{/if}}
      {{/unless}}
    </div>
    <label id="advanced" class="checkbox">
      <input 
        name="show_advanced" 
        type="checkbox" 
        hx-on:change="htmx.toggleClass('#advanced-options', 'hidden')"
        {{#if show_advanced}}checked="true"{{/if}}
      />
      Show advanced options
    </label>
    <section id="advanced-options" class="{{#unless show_advanced}}hidden{{/unless}}">
      <div class="advanced-input-wrapper">
        <label class="{{#if errors.domain}}error{{/if}}">
          Domain:
          <select 
            id="domain" 
            name="domain" 
            hx-preserve="true" 
            hx-on:change="
              const elm = document.querySelector('#customurl-label span');
              if (!elm) return;
              elm.textContent = event.target.value + '/';
            "
          >
            <option value={{default_domain}}>{{default_domain}}</option>
            {{#each domains}}
              <option value={{address}}>{{address}}</option>
            {{/each}}
          </select>
          {{#if errors.domain}}<p class="error">{{errors.domain}}</p>{{/if}}
        </label>
        <label id="customurl-label" class="{{#if errors.customurl}}error{{/if}}">
          <span id="customurl-label-value" hx-preserve="true">{{default_domain}}/</span>
          <input
            type="text" 
            id="customurl" 
            name="customurl" 
            placeholder="Custom address..." 
            hx-preserve="true"
            autocomplete="off" 
          />
          {{#if errors.customurl}}<p class="error">{{errors.customurl}}</p>{{/if}}
        </label>
        <label class="{{#if errors.password}}error{{/if}}">
          Password:
          <input 
            type="password" 
            id="password" 
            name="password" 
            placeholder="Password..." 
            hx-preserve="true" 
            autocomplete="new-password"
          />
          {{#if errors.password}}<p class="error">{{errors.password}}</p>{{/if}}
        </label>
      </div>
      <div class="advanced-input-wrapper">
        <label class="expire-in {{#if errors.expire_in}}error{{/if}}">
          Expire in:
          <input
            type="text"
            id="expire_in"
            name="expire_in"
            placeholder="2 minutes/hours/days"
            hx-preserve="true"
          />
          {{#if errors.expire_in}}<p class="error">{{errors.expire_in}}</p>{{/if}}
        </label>
        <label class="description {{#if errors.description}}error{{/if}}">
          Description:
          <input
            type="text"
            id="description"
            name="description"
            placeholder="Description..."
            hx-preserve="true"
          />
          {{#if errors.description}}<p class="error">{{errors.description}}</p>{{/if}}
        </label>
      </div>
    </section>

    <label id="utm-toggle" class="checkbox">
      <input
        name="show_utm"
        type="checkbox"
        id="show_utm"
        hx-on:change="htmx.toggleClass('#utm-options', 'hidden'); if(!window._utmLoaded){loadUtmData();}"
      />
      Add UTM parameters
    </label>
    <section id="utm-options" class="utm-section hidden">

      {{!-- Channel presets --}}
      <div class="utm-block">
        <p class="utm-block-title">Channel <span class="utm-hint">(sets source + medium)</span></p>
        <div class="utm-channels" id="utm-channels">
          <button type="button" class="utm-channel-btn" data-source="instagram" data-medium="social"     onclick="selectUtmChannel(this)">📷 Instagram</button>
          <button type="button" class="utm-channel-btn" data-source="instagram" data-medium="stories"    onclick="selectUtmChannel(this)">🎞 Stories</button>
          <button type="button" class="utm-channel-btn" data-source="instagram" data-medium="reels"      onclick="selectUtmChannel(this)">🎬 Reels</button>
          <button type="button" class="utm-channel-btn" data-source="youtube"   data-medium="social"     onclick="selectUtmChannel(this)">▶️ YouTube</button>
          <button type="button" class="utm-channel-btn" data-source="whatsapp"  data-medium="social"     onclick="selectUtmChannel(this)">💬 WhatsApp</button>
          <button type="button" class="utm-channel-btn" data-source="email"     data-medium="email"      onclick="selectUtmChannel(this)">✉️ E-mail</button>
          <button type="button" class="utm-channel-btn" data-source="google"    data-medium="cpc"        onclick="selectUtmChannel(this)">🔍 Google Ads</button>
          <button type="button" class="utm-channel-btn" data-source="google"    data-medium="organic"    onclick="selectUtmChannel(this)">🌱 Orgânico</button>
          <button type="button" class="utm-channel-btn" data-source=""          data-medium=""           onclick="selectUtmChannel(this)">✏️ Outro</button>
        </div>
        <div id="utm-source-medium-row" class="utm-source-medium hidden">
          <label>Source: <input type="text" id="utm_source" data-utm="utm_source" placeholder="fonte" oninput="updateUtmPreview()" autocomplete="off" /></label>
          <label>Medium: <input type="text" id="utm_medium" data-utm="utm_medium" placeholder="midia" oninput="updateUtmPreview()" autocomplete="off" /></label>
        </div>
      </div>

      {{!-- Saved presets --}}
      <div class="utm-block" id="utm-presets-block">
        <p class="utm-block-title">Saved Presets <a class="nav utm-manage-link" href="/settings#utm-presets" target="_blank">Manage</a></p>
        <div id="utm-presets-list" class="utm-presets-list">
          <span class="utm-hint">Loading...</span>
        </div>
      </div>

      {{!-- Campaign --}}
      <div class="utm-block">
        <p class="utm-block-title">Campaign</p>
        <div class="utm-campaign-row">
          <input type="text" id="utm_campaign" data-utm="utm_campaign" placeholder="black-friday-2026" oninput="updateUtmPreview(); filterCampaignHistory(this.value)" autocomplete="off" class="utm-campaign-input" />
          <div id="utm-campaign-history" class="utm-campaign-history hidden"></div>
        </div>
      </div>

      {{!-- Content --}}
      <div class="utm-block">
        <p class="utm-block-title">Content <span class="utm-hint">(optional — differentiates creatives)</span></p>
        <div id="utm-content-suggestions" class="utm-channels"></div>
        <input type="text" id="utm_content" data-utm="utm_content" placeholder="ex: bio, feed-post, stories-swipe" oninput="updateUtmPreview()" autocomplete="off" class="utm-content-input" />
      </div>

      {{!-- Term (Google Ads only) --}}
      <div class="utm-block hidden" id="utm-term-block">
        <p class="utm-block-title">Term <span class="utm-hint">(keyword paga — Google Ads)</span></p>
        <input type="text" id="utm_term" data-utm="utm_term" placeholder="palavra-chave" oninput="updateUtmPreview()" autocomplete="off" class="utm-content-input" />
      </div>

      {{!-- Preview + actions --}}
      <div id="utm-preview" class="utm-preview hidden">
        <span class="utm-preview-label">Preview:</span>
        <span id="utm-preview-url"></span>
      </div>
      <div class="utm-footer">
        <button type="button" class="button utm-clear-btn" onclick="clearUtmFields()">Clear UTMs</button>
      </div>

    </section>
  </form>
</main>
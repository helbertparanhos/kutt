{{> header}}
<section id="dashboard" class="dashboard-page">

  <div class="dash-topbar">
    <h1 class="dash-title">Dashboard</h1>
    <div class="dash-actions">
      <a class="button" href="/api/v2/links/export?format=csv" download>
        {{> icons/write}}&nbsp;Export CSV
      </a>
      <a class="button secondary" href="/api/docs" target="_blank">API Docs</a>
    </div>
  </div>

  <div class="dash-kpis">
    <div class="dash-kpi">
      <span class="kpi-value">{{total_links}}</span>
      <span class="kpi-label">Total Links</span>
    </div>
    <div class="dash-kpi">
      <span class="kpi-value primary">{{total_clicks}}</span>
      <span class="kpi-label">Total Clicks</span>
    </div>
    <div class="dash-kpi">
      <span class="kpi-value">{{avg_clicks}}</span>
      <span class="kpi-label">Avg Clicks / Link</span>
    </div>
    <div class="dash-kpi">
      <span class="kpi-value secondary">{{links_last_30_days}}</span>
      <span class="kpi-label">Links (Last 30 Days)</span>
    </div>
  </div>

  <div class="dash-grid">

    <div class="dash-card dash-card-wide">
      <div class="dash-card-header">
        <h2>Top 10 Links by Clicks</h2>
      </div>
      <div class="dash-chart-wrap">
        <canvas id="topLinksChart"></canvas>
      </div>
      <table class="dash-table dash-top">
        <thead>
          <tr>
            <th class="col-rank">#</th>
            <th class="col-slug">Slug</th>
            <th class="col-dest">Destination</th>
            <th class="col-clicks">Clicks</th>
            <th class="col-action"></th>
          </tr>
        </thead>
        <tbody>
          {{#each top_links}}
          <tr>
            <td class="col-rank dash-rank">{{addOne @index}}</td>
            <td class="col-slug"><strong>{{address}}</strong></td>
            <td class="col-dest">{{target}}</td>
            <td class="col-clicks"><strong>{{visit_count}}</strong></td>
            <td class="col-action">
              <button type="button" class="button small" onclick="openStatsModal('{{id}}')" title="Ver stats">{{> icons/chart}}</button>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

    <div class="dash-card">
      <div class="dash-card-header">
        <h2>Recently Created</h2>
        <a class="nav" href="/">+ New link</a>
      </div>
      <table class="dash-table dash-recent">
        <thead>
          <tr>
            <th class="col-slug">Slug</th>
            <th class="col-clicks">Clicks</th>
            <th class="col-action"></th>
          </tr>
        </thead>
        <tbody>
          {{#each recently_created}}
          <tr>
            <td class="col-slug">
              <strong>{{address}}</strong>
              <span class="dash-slug-sub">{{relative_created_at}}</span>
            </td>
            <td class="col-clicks">{{visit_count}}</td>
            <td class="col-action">
              <button type="button" class="button small" onclick="openStatsModal('{{id}}')" title="Ver stats">{{> icons/chart}}</button>
            </td>
          </tr>
          {{/each}}
        </tbody>
      </table>
    </div>

  </div>

</section>

{{!-- Stats Modal --}}
<div id="stats-modal-overlay" class="stats-modal-overlay hidden" onclick="closeStatsModal(event)">
  <div class="stats-modal-card">
    <button type="button" class="stats-modal-close" onclick="closeStatsModal()" aria-label="Close">{{> icons/x}}</button>
    <div id="stats-modal-content">
      <div class="loading-stats">{{> icons/spinner}} Loading stats...</div>
    </div>
  </div>
</div>

{{> footer}}

{{#extend "scripts"}}
<script src="/libs/chart.min.js"></script>
<script src="/scripts/stats.js"></script>
<script>
(function () {
  var data = {{{top_links_json}}};
  if (!data || !data.length) return;
  var ctx = document.getElementById("topLinksChart");
  if (!ctx) return;
  new Chart(ctx, {
    type: "bar",
    data: {
      labels: data.map(function(d){ return d.label; }),
      datasets: [{
        label: "Clicks",
        data: data.map(function(d){ return d.value; }),
        backgroundColor: [
          "hsla(207,90%,54%,0.75)","hsla(262,47%,55%,0.75)",
          "hsla(144,50%,50%,0.75)","hsla(35,90%,54%,0.75)",
          "hsla(0,80%,55%,0.75)","hsla(180,70%,45%,0.75)",
          "hsla(300,50%,55%,0.75)","hsla(60,80%,48%,0.75)"
        ],
        borderRadius: 6,
        borderWidth: 0,
      }]
    },
    options: {
      responsive: true,
      plugins: { legend: { display: false } },
      scales: {
        y: { beginAtZero: true, grid: { color: "hsla(200,20%,85%,0.5)" } },
        x: { grid: { display: false } }
      }
    }
  });
}());

function openStatsModal(linkId) {
  var overlay = document.getElementById("stats-modal-overlay");
  var content = document.getElementById("stats-modal-content");
  content.innerHTML = "<div class='loading-stats'>{{> icons/spinner}} Loading stats...</div>";
  overlay.classList.remove("hidden");
  document.body.style.overflow = "hidden";
  htmx.ajax("GET", "/api/links/" + linkId + "/stats", {
    target: "#stats-modal-content",
    swap: "innerHTML",
  }).then(function() {
    trimText(".stats-info p", 80);
    formatDateHour("#stats .last-update-value");
    createCharts();
  });
}

function closeStatsModal(evt) {
  if (evt && evt.target !== document.getElementById("stats-modal-overlay") && !evt.target.closest(".stats-modal-close")) return;
  document.getElementById("stats-modal-overlay").classList.add("hidden");
  document.body.style.overflow = "";
}
</script>
{{/extend}}
